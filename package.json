{
  "name": "pi-openai-compatible",
  "version": "0.70.6",
  "description": "Pi extension for configuring OpenAI-compatible providers with guided setup and model discovery.",
  "type": "module",
  "license": "MIT",
  "keywords": ["pi", "pi-extension", "openai-compatible", "llm", "provider"],
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "test": "node --test index.test.ts",
    "check": "npm run test && npm run typecheck && npm run lint",
    "typecheck": "tsc --noEmit",
    "format": "biome format --write .",
    "lint": "biome check .",
    "knip": "knip"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "knip": "^5.61.3",
    "typescript": "^5.9.3"
  },
  "pi": {
    "extensions": ["./index.ts"]
  }
}
